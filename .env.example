# 月影车姬机器人 — 环境变量配置模板
# 复制为 .env 并填入实际值

# Telegram Bot Token（从 @BotFather 获取）
BOT_TOKEN=your_telegram_bot_token_here

# MongoDB 连接 URI（Docker Compose 中使用服务名）
MONGO_URI=mongodb://mongo:27017/

# 管理员 Telegram ID（逗号分隔）
ADMIN_IDS=123456789,987654321

# Mini App HTTPS URL（需 HTTPS，例如 Nginx 反代后的域名）
MINI_APP_URL=https://yourdomain.com/mini_app.html

# AI API Key（二选一或留空）
GROK_API_KEY=
TONGYI_API_KEY=

# Web API 端口（默认 8080）
WEB_PORT=8080

# 运行环境（dev 跳过 initData 验证，生产请勿使用）
ENV=production

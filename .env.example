# 月影车姬机器人 — 环境变量配置模板
# 复制为 .env 并填入实际值

# Telegram Bot Token（从 @BotFather 获取）
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL 数据库连接 URL（Railway 自动注入此变量）
# 格式：postgresql://user:password@host:port/database
# Railway 会提供：postgresql://postgres:xxx@xxx.railway.internal:5432/railway
DATABASE_URL=postgresql://user:password@localhost:5432/yueyingcheji

# 管理员 Telegram ID（逗号分隔）
ADMIN_IDS=123456789,987654321

# Mini App HTTPS URL（需 HTTPS，Railway 部署后自动获得）
MINI_APP_URL=https://your-service.up.railway.app/mini_app.html

# Telegram Webhook 公开 URL（Railway 部署时填写，本地开发可留空使用长轮询）
# 格式：https://your-service.up.railway.app（不含尾斜杠和路径）
WEBHOOK_URL=https://your-service.up.railway.app

# AI API Key（二选一或留空，留空时 AI 功能降级为规则模式）
GROK_API_KEY=
TONGYI_API_KEY=

# 监听端口（Railway 自动注入 $PORT，通常无需手动设置）
PORT=8080

# 运行环境（dev 跳过 initData 验证，生产请勿使用）
ENV=production
